rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Contact form submissions — anyone can write, no client read
    match /thaiskill_contacts/{docId} {
      allow create: if true;
      allow read, update, delete: if false;
    }

    // Public comments — anyone can read and post
    match /thaiskill_comments/{docId} {
      allow read, create: if true;
      allow update, delete: if false;
    }

  }
}
