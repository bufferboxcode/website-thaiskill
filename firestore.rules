rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Contact form submissions ──────────────────────────────
    // Anyone can write, no one can read from client (admin only via Firebase Console)
    match /thaiskill_contacts/{docId} {
      allow create: if
        request.resource.data.keys().hasAll(['name', 'email', 'message', 'createdAt']) &&
        request.resource.data.name   is string && request.resource.data.name.size()    <= 100 &&
        request.resource.data.email  is string && request.resource.data.email.size()   <= 200 &&
        request.resource.data.message is string && request.resource.data.message.size() <= 2000;
      allow read: if false;  // read via Firebase Console only
    }

    // ── Public comments ───────────────────────────────────────
    // Anyone can read + write (no auth required — matches masabqurban.com pattern)
    match /thaiskill_comments/{docId} {
      allow read: if true;
      allow create: if
        request.resource.data.keys().hasAll(['name', 'message', 'createdAt']) &&
        request.resource.data.name    is string && request.resource.data.name.size()    <= 100 &&
        request.resource.data.message is string && request.resource.data.message.size() <= 1000;
      allow update, delete: if false;  // ป้องกันการแก้ไข/ลบ
    }

  }
}
