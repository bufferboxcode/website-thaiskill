# ── ThaiSkill Environment Variables ──────────────────────────
# คัดลอกเป็น .env.local แล้วใส่ค่าจริง
# ไฟล์ .env.local จะไม่ถูก commit เข้า git

# ── Contact form (Formspree) ──────────────────────────────────
# วิธีได้ Formspree ID (ฟรี ไม่ต้อง credit card):
#   1. ไปที่ https://formspree.io → Sign up
#   2. "+ New Form" → ตั้งชื่อ เช่น "ThaiSkill Contact"
#   3. คัดลอก ID จาก URL เช่น https://formspree.io/f/xabcdefg
#      → ID คือ "xabcdefg"
NEXT_PUBLIC_FORMSPREE_CONTACT=xabcdefg

# ── Comments form (Google Apps Script → Google Sheet) ─────────
# วิธีได้ URL (ดูไฟล์ gas-comments-template.js สำหรับขั้นตอนเต็ม):
#   1. เปิด Google Sheet → Extensions → Apps Script
#   2. วางโค้ดจาก gas-comments-template.js
#   3. Deploy → New Deployment → Web app → Anyone → Copy URL
NEXT_PUBLIC_GAS_COMMENTS_URL=https://script.google.com/macros/s/YOUR_SCRIPT_ID/exec

# ── วิธีใส่ใน Vercel ─────────────────────────────────────────
#   Settings → Environment Variables → Add ตัวแปรด้านบน → Save → Redeploy
