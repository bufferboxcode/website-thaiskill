# ── Environment Variables สำหรับ ThaiSkill ──────────────────────────
# คัดลอกไฟล์นี้เป็น .env.local แล้วใส่ค่าจริง
# (ไฟล์ .env.local จะไม่ถูก commit เข้า git)
#
# วิธีได้ GAS_URL:
#   1. Deploy Google Apps Script ตาม gas-script-template.js
#   2. คัดลอก Web app URL ที่ได้หลัง Deploy
#   3. นำ URL มาใส่ด้านล่าง
#
# วิธีตั้งค่าบน Vercel:
#   Settings → Environment Variables → Add → GAS_URL = <URL>

GAS_URL=https://script.google.com/macros/s/YOUR_SCRIPT_ID/exec
