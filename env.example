# ── ThaiSkill Environment Variables ──────────────────────────
# คัดลอกเป็น .env.local แล้วใส่ค่าจริง
# ไฟล์ .env.local จะไม่ถูก commit เข้า git
#
# วิธีได้ค่า Supabase:
#   1. สมัคร https://supabase.com (ฟรี)
#   2. Create new project
#   3. SQL Editor → วาง supabase-setup.sql → Run
#   4. Settings → API → คัดลอก URL และ anon key

SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
