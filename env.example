# ── ThaiSkill Environment Variables ──────────────────────────
# คัดลอกเป็น .env.local แล้วใส่ค่าจริง
# ไฟล์ .env.local จะไม่ถูก commit เข้า git
#
# วิธีได้ Formspree ID (ฟรี ไม่ต้อง credit card):
#   1. ไปที่ https://formspree.io → Sign up (ใช้ Gmail ได้)
#   2. "+ New Form" → ตั้งชื่อ เช่น "ThaiSkill Contact"
#   3. คัดลอก ID จาก URL ที่ได้ เช่น https://formspree.io/f/xabcdefg
#      → ID คือ "xabcdefg" (ส่วนหลัง /f/)
#   4. สร้างอีก 1 form สำหรับ Comments
#   5. ใส่ทั้งสอง ID ด้านล่าง

NEXT_PUBLIC_FORMSPREE_CONTACT=xabcdefg
NEXT_PUBLIC_FORMSPREE_COMMENTS=xhijklmn

# วิธีใส่ใน Vercel:
#   Settings → Environment Variables → Add
#   ใส่ทั้ง 2 ตัวแล้ว Save → Redeploy
