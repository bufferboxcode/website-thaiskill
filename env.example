# ── ThaiSkill Environment Variables ──────────────────────────
# คัดลอกเป็น .env.local แล้วใส่ค่าจริง
# ไฟล์ .env.local จะไม่ถูก commit เข้า git

# ── Firebase (Contact form + Real-time Comments) ──────────────
# วิธีได้ค่าเหล่านี้:
#   1. ไปที่ https://console.firebase.google.com
#   2. "+ Add project" → ตั้งชื่อ เช่น "thaiskill-dashboard"
#   3. Project Overview → "</> Add app" → Web
#   4. ตั้งชื่อ app → Register → คัดลอก firebaseConfig object
#   5. ใส่ค่าแต่ละตัวด้านล่าง

NEXT_PUBLIC_FIREBASE_API_KEY=AIzaSy...
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your-project-id
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your-project.firebasestorage.app
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=123456789012
NEXT_PUBLIC_FIREBASE_APP_ID=1:123456789012:web:abc123

# ── วิธีตั้งค่า Firestore ─────────────────────────────────────
#   1. Firebase Console → Firestore Database → Create database
#   2. เลือก "Start in test mode" → Next → Create
#   3. ไปที่ Rules → วาง rules จากไฟล์ firestore.rules → Publish
#
# Collections ที่จะถูกสร้างอัตโนมัติเมื่อมีการส่งข้อมูล:
#   - thaiskill_contacts  (contact form — อ่านได้เฉพาะ Firebase Console)
#   - thaiskill_comments  (public comments — real-time)

# ── วิธีใส่ใน Vercel ─────────────────────────────────────────
#   Settings → Environment Variables → Add ทีละตัว → Save → Redeploy
